{
  "name": "gleaned",
  "version": "0.6.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "NODE_OPTIONS=--disable-warning=DEP0205 vitest run",
    "test:watch": "NODE_OPTIONS=--disable-warning=DEP0205 vitest",
    "test:coverage": "NODE_OPTIONS=--disable-warning=DEP0205 vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prestart": "drizzle-kit migrate",
    "prepare": "[ -d .git ] && git config core.hooksPath .githooks && chmod +x .githooks/pre-commit || true"
  },
  "dependencies": {
    "@fontsource-variable/caveat": "^5.2.8",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "next": "16.2.9",
    "node-cron": "^4.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "web-push": "^3.6.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "leveldown",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1",
      "@esbuild-kit/core-utils>esbuild": ">=0.25.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
