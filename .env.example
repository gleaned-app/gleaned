# CouchDB credentials — used by docker-compose
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme

# PouchDB sync target — exposed to the browser
# Dev (docker-compose.dev.yml + pnpm dev):
NEXT_PUBLIC_COUCHDB_URL=http://admin:changeme@localhost:5984/gleaned

# Prod (docker-compose.yml, internal docker network):
# NEXT_PUBLIC_COUCHDB_URL=http://admin:changeme@couchdb:5984/gleaned
