# Copy this file to .env and fill in the values.
#
#   cp docker/.env.example docker/.env
#
# ── Traefik (docker/compose.traefik.yml only) ────────────────────────────────
DOMAIN=gleaned.example.com
TRAEFIK_NETWORK=frontend
CERT_RESOLVER=letsencrypt

# ── Image ─────────────────────────────────────────────────────────────────────
# For production, pin to a specific image digest instead of :latest to prevent
# unexpected changes if the registry image is ever replaced.
#
#   Get the current digest after pulling:
#     docker pull ghcr.io/gleaned-app/gleaned:latest
#     docker inspect --format='{{index .RepoDigests 0}}' ghcr.io/gleaned-app/gleaned:latest
#
#   Then set:
#     GLEANED_IMAGE=ghcr.io/gleaned-app/gleaned@sha256:<digest>
#
# Defaults to :latest when unset (fine for local/dev use, not recommended for production).
GLEANED_IMAGE=ghcr.io/gleaned-app/gleaned:latest

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/data/gleaned.db

# ── Proxy ─────────────────────────────────────────────────────────────────────
# Controls whether gleaned trusts X-Forwarded-For / X-Real-IP headers for
# rate limiting. Set this correctly — a wrong value makes brute-force
# protection either ineffective or misleading.
#
#   true  — gleaned is behind a reverse proxy (Traefik, nginx, Caddy) that
#            injects the forwarded headers. Use this with compose.traefik.yml
#            or any setup where a proxy sits in front of port 3000.
#            (compose.traefik.yml sets this automatically.)
#
#   false — gleaned is exposed directly (port-only Docker, pnpm dev).
#            Headers are attacker-controlled and must not be trusted.
#            X-Forwarded-For is ignored; the raw socket IP is used instead.
TRUST_PROXY=false

# ── Import ────────────────────────────────────────────────────────────────────
# Maximum size of a single import payload in megabytes (default: 50).
# Raise this if you have many large attachments in your export.
MAX_IMPORT_MB=50

# ── Push notifications (optional) ─────────────────────────────────────────────
# If VAPID keys are not set, push notifications are silently disabled.
# Generate once with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Rotating these keys invalidates all existing browser subscriptions.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Secret for POST /api/push/send (manual broadcast). Required if push is enabled.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SEND_SECRET=

# Reminder schedule (24h, server timezone)
PUSH_HOUR=20
PUSH_MINUTE=0
DUE_HOUR=9
DUE_MINUTE=0

# Timezone for cron schedules and "today" calculation (e.g. Europe/Berlin)
PUSH_TZ=UTC
