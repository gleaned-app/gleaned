# Copy this file to .env in the repo root — Docker Compose picks it up
# automatically when run from there.
#
#   cp docker/.env.example .env
#
# ── Traefik (docker/compose.traefik.yml only) ────────────────────────────────
DOMAIN=gleaned.example.com
TRAEFIK_NETWORK=frontend
CERT_RESOLVER=letsencrypt

# ── CouchDB credentials ───────────────────────────────────────────────────────
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme

# ── Sync auto-config (compose.yml only) ───────────────────────────────────────
# When set, the app pre-fills the sync URL in Settings so users don't have to
# type it manually. Only the URL and username are exposed — never the password.
# compose.traefik.yml sets this automatically from DOMAIN; for port-based
# deployments the app derives the URL from window.location.origin, so this
# variable is optional.
# GLEANED_SYNC_URL=http://your-ip:3000/db/gleaned

# VAPID keys for Web Push — generate once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# or run inside the pusher container:
#   docker compose run --rm pusher node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Daily learning reminder time (24h, server timezone)
PUSH_HOUR=20
PUSH_MINUTE=0

# Due-date reminder time — checks for todos due today + overdue (default: 09:00)
DUE_HOUR=9
DUE_MINUTE=0

# Secret for POST /push/send — REQUIRED. An empty value is rejected at startup.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SEND_SECRET=
